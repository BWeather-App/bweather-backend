APP_NAME=BWeather
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack

DB_CONNECTION=sqlite

SESSION_DRIVER=file

CACHE_STORE=file

# Cache TTL untuk data cuaca (dalam menit). Default: 30.
WEATHER_CACHE_TTL=30

# ─────────────────────────────────────────────
# Third-party API Keys
# ─────────────────────────────────────────────

# WeatherAPI — ambil dari https://www.weatherapi.com/
WEATHERAPI_API_KEY=
WEATHERAPI_BASE_URL=https://api.weatherapi.com/v1

# OpenCage Geocoding — ambil dari https://opencagedata.com/
GEOCODING_API_KEY=

# Firebase Cloud Messaging — untuk push notification
# FCM_SERVICE_ACCOUNT=app/firebase/bweather-app-firebase-adminsdk.json
